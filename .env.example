COMPOSE_PROJECT_NAME=idem-core
SERVER_HOST=localhost

PUBLIC_FRONTEND_PORT=3000
PUBLIC_BACKEND_PORT=8080
PUBLIC_POSTGRES_PORT=5432
PUBLIC_KAFKA_PORT=9094
PUBLIC_KAFKA_UI_PORT=8085

POSTGRES_DB=idem_core
POSTGRES_USER=idem
POSTGRES_PASSWORD=idem_password

# --- Ручной режим по ветке / тегу ---
# Эти переменные нужны только для ./up.sh (deploy.sh),
# когда хочешь с сервера вручную указать, какой ref брать из удалённого Git.
GLOBAL_REF=main
BACKEND_REF=
FRONTEND_REF=

# Если оба сервиса лежат в одном и том же репозитории, достаточно REPO_URL.
REPO_URL=git@github.com:idempotence-service/core.git
BACKEND_REPO_URL=
FRONTEND_REPO_URL=

# Пути до сервисов внутри репозитория.
BACKEND_SUBDIR=backend
FRONTEND_SUBDIR=frontend

# Куда deploy.sh будет складывать временные checkout-ы.
DEPLOY_DIR=.deploy
